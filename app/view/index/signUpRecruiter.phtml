<div id="signup-page">
    <div class="signup-card">

        <!-- LADO INFORMATIVO -->
        <div class="signup-side-info">
            <div class="mb-5">
                <img src="Logo deployme.png" alt="Deployme" style="height: 38px; filter: brightness(0) invert(1);" onerror="this.style.display='none'">
            </div>

            <h2 class="display-6 fw-800 mb-4">
                Encontre talentos de TI.
            </h2>

            <p class="lead opacity-75 mb-5">
                Conecte-se com estudantes prontos para o mercado.
            </p>

            <div class="mt-auto pt-5">
                <small class="opacity-50">Lançamento em 2026 • Deployme Hub</small>
            </div>
        </div>

        <!-- FORM -->
        <div class="signup-form-side">

            <a href="/" class="back-link">
                <i class="bi bi-arrow-left me-2"></i> Voltar à Home
            </a>

            <div class="mb-5">
                <h3 class="fw-800 mb-2">Criar Conta</h3>
                <p class="text-muted">Informe os dados do seu perfil abaixo.</p>
            </div>

            <form id="registrationForm">
                <input type="hidden" id="user-role" value="recruiter">

                <div class="row g-4">

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Nome Completo" required>
                            <label>Nome Completo</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="email" class="form-control" placeholder="E-mail" required>
                            <label>E-mail de Contato</label>
                        </div>
                    </div>

                    <!-- CAMPOS RECRUTADOR -->
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Empresa">
                            <label>Empresa Atual</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <select class="form-select">
                                <option selected disabled>Escolha...</option>
                                <option>Junior TA</option>
                                <option>Pleno Recruiter</option>
                                <option>Senior Consultant</option>
                            </select>
                            <label>Nível Hierárquico</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="password" class="form-control" placeholder="Senha" required>
                            <label>Defina uma Senha</label>
                        </div>
                    </div>

                </div>

                <div class="form-check my-4">
                    <input class="form-check-input" type="checkbox" required>
                    <label class="form-check-label text-muted small">
                        Aceito as diretrizes da Deployme para 2026.
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow-lg">
                    Criar Perfil Agora
                </button>
            </form>

        </div>
    </div>
</div>