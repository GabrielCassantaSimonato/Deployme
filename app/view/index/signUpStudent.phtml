<div id="signup-page">
    <div class="signup-card">

        <!-- LADO INFORMATIVO -->
        <div class="signup-side-info">
            <div class="mb-5">
                <img src="Logo deployme.png" alt="Deployme" style="height: 38px; filter: brightness(0) invert(1);" onerror="this.style.display='none'">
            </div>

            <h2 class="display-6 fw-800 mb-4">
                A sua jornada começa aqui.
            </h2>

            <p class="lead opacity-75 mb-5">
                Acesso a vagas reais e networking especializado.
            </p>

            <div class="d-flex flex-column gap-4">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-check-circle-fill text-primary"></i>
                    <span>Perfil especializado em TI</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-check-circle-fill text-primary"></i>
                    <span>Conexão direta mercado-aluno</span>
                </div>
            </div>

            <div class="mt-auto pt-5">
                <small class="opacity-50">Lançamento em 2026 • Deployme Hub</small>
            </div>
        </div>

        <!-- FORM -->
        <div class="signup-form-side">

            <a href="/" class="back-link">
                <i class="bi bi-arrow-left me-2"></i> Voltar à Home
            </a>

            <div class="mb-5">
                <h3 class="fw-800 mb-2">Criar Conta</h3>
                <p class="text-muted">Informe os dados do seu perfil abaixo.</p>
            </div>

            <form id="registrationForm">
                <input type="hidden" id="user-role" value="student">

                <div class="row g-4">

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="text" class="form-control" id="fullName" placeholder="Nome Completo" required>
                            <label>Nome Completo</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="email" class="form-control" id="email" placeholder="E-mail" required>
                            <label>E-mail de Contato</label>
                        </div>
                    </div>

                    <!-- CAMPOS ESTUDANTE -->
                    <div class="col-12">
                        <label class="form-label fw-700 text-dark mb-2">Seu Perfil Profissional</label>

                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="course" placeholder="Curso">
                            <label>Qual o seu curso atual?</label>
                        </div>

                        <div class="github-input-group input-group">
                            <span class="input-group-text"><i class="bi bi-github"></i></span>
                            <div class="form-floating flex-grow-1">
                                <input type="text" class="form-control" id="github-user" placeholder="GitHub User">
                                <label>Username do GitHub</label>
                            </div>
                        </div>

                        <div id="github-feedback">
                            <img id="github-avatar" src="" alt="">
                            <div class="ms-3">
                                <div id="github-status" class="small fw-800">Sincronizando...</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Perfil validado com sucesso!</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-floating">
                            <input type="password" class="form-control" id="password" placeholder="Senha" required>
                            <label>Defina uma Senha</label>
                        </div>
                    </div>

                </div>

                <div class="form-check my-4">
                    <input class="form-check-input" type="checkbox" required>
                    <label class="form-check-label text-muted small">
                        Aceito as diretrizes da Deployme para 2026.
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow-lg">
                    Criar Perfil Agora
                </button>
            </form>

        </div>
    </div>
</div>