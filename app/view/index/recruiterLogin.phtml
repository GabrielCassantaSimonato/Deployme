<!-- FORMULÁRIO DE LOGIN -->
<div id="login-form-view" class="view-transition">
    <div id="login-form-page">
        <div class="login-premium-container">
            <a href="/" class="back-link mb-4 text-decoration-none">
                <i class="bi bi-arrow-left me-2"></i> Voltar à Home
            </a>

            <div class="login-avatar-ring">
                <i class="bi bi-buildings" id="login-avatar-icon"></i>
            </div>

            <h3 class="fw-800 mb-5 text-dark" id="login-heading">Login de Recrutador</h3>

            <form>
                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="loginEmail" placeholder="E-mail" required>
                    <label for="loginEmail">E-mail</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="password" class="form-control" id="loginPass" placeholder="Senha" required>
                    <label for="loginPass">Senha</label>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                    <a href="#" class="small text-primary text-decoration-none fw-600">Esqueci a senha</a>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow-lg mb-4">
                    Entrar
                </button>

                <div class="text-center">
                    <span class="small text-muted">Ainda não tem conta?</span>
                    <a href="#" id="dynamic-signup-link"
                        class="small text-primary text-decoration-none fw-800 ms-1">Registe-se aqui</a>
                </div>

                <hr class="my-4 opacity-50">

                <a href="/loginSelection" class="btn btn-light btn-sm rounded-pill px-4 text-muted fw-600">
                    Alterar Perfil
                </a>
            </form>
        </div>
    </div>
</div>