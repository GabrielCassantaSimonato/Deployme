    <script>
        document.addEventListener('DOMContentLoaded', () => {
            <?php
            // Dispara via JS a abertura da modal se houver confirmação na query string de edição salva de post
            if (isset($_GET['edit']) && $_GET['edit'] == 'post_sucesso') {
            ?>
                new bootstrap.Modal(document.getElementById('modalEditPostSucesso')).show();
