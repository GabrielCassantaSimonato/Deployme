<script>

    document
        .querySelectorAll('.filtro')
        .forEach(input => {

            input.addEventListener(
                'keyup',
                filtrarUsuarios
            );

        });

    function filtrarUsuarios() {
        const filtros =
            Array.from(
                document.querySelectorAll('.filtro')
            )
                .map(
                    campo => campo.value.toLowerCase()
                );

        document
            .querySelectorAll('.usuario-card')
            .forEach(card => {

                const texto =
                    card.innerText.toLowerCase();

                const exibir =
                    filtros.every(
                        filtro =>
                            !filtro ||
                            texto.includes(filtro)
                    );

                card.style.display =
                    exibir
                        ? ''
                        : 'none';

            });

    }

</script>