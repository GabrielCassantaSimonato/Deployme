<script>
    document.getElementById('btnSeguidores').addEventListener('click', function () {
        document.getElementById('listaSeguidores').style.display = 'block';
        document.getElementById('listaSeguindo').style.display = 'none';

        this.classList.remove('btn-outline-primary');
        this.classList.add('btn-primary');

        document.getElementById('btnSeguindo').classList.remove('btn-primary');
        document.getElementById('btnSeguindo').classList.add('btn-outline-primary');
    });

    document.getElementById('btnSeguindo').addEventListener('click', function () {
        document.getElementById('listaSeguidores').style.display = 'none';
        document.getElementById('listaSeguindo').style.display = 'block';

        this.classList.remove('btn-outline-primary');
        this.classList.add('btn-primary');

        document.getElementById('btnSeguidores').classList.remove('btn-primary');
        document.getElementById('btnSeguidores').classList.add('btn-outline-primary');
    });
</script>