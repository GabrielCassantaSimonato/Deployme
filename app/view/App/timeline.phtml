<script>
  document.addEventListener('DOMContentLoaded', () => {
    <?php if (isset($_GET['post']) && $_GET['post'] == 'sucesso') { ?>
      new bootstrap.Modal(document.getElementById('modalPostSucesso')).show();
    <?php } ?>

    <?php if (isset($_GET['vaga']) && $_GET['vaga'] == 'sucesso') { ?>
      new bootstrap.Modal(document.getElementById('modalVagaSucesso')).show();
    <?php } ?>

    <?php if (isset($_GET['edit']) && $_GET['edit'] == 'post_sucesso') { ?>
      new bootstrap.Modal(document.getElementById('modalEditPostSucesso')).show();
    <?php } ?>

    <?php if (isset($_GET['edit']) && $_GET['edit'] == 'vaga_sucesso') { ?>
      new bootstrap.Modal(document.getElementById('modalEditVagaSucesso')).show();
    <?php } ?>

    <?php if (isset($_GET['delete']) && $_GET['delete'] == 'success') { ?>
      new bootstrap.Modal(document.getElementById('modalDeleteSucesso')).show();
    <?php } ?>

    <?php if (isset($_GET['moderacao'])) { ?>
      new bootstrap.Modal(document.getElementById('modalModeracao')).show();
    <?php } ?>

    <?php if (isset($_GET['share']) && $_GET['share'] == 'sucesso') { ?>
      new bootstrap.Modal(document.getElementById('modalShareSucesso')).show();
    <?php } ?>
  });

  // Abertura do modal de edição (Funciona para comentários antigos e novos!)
  document.addEventListener('click', function (e) {
    // O closest garante que funciona mesmo se clicar no ícone ✏️ dentro do botão
    const btnEditar = e.target.closest('.editar-comentario-btn');

    if (btnEditar) {
      e.preventDefault(); // Evita que o link faça a página pular

      // Preenche os dados no modal
      document.getElementById('editComentarioId').value = btnEditar.dataset.id;
      document.getElementById('editComentarioTexto').value = btnEditar.dataset.comentario;

      // Abre o modal de forma segura
      const modalElement = document.getElementById('editarComentarioModal');
      const modalInstance = bootstrap.Modal.getOrCreateInstance(modalElement);
      modalInstance.show();
    }
  });
</script>